tempo 12!0;
time_sign@!#ature 4/4;
key D#;

# This is a comment
pattern intro_1 {
    play A3 from 0;
    play A2/2 from 1;
    play (B3, C3/2, Gb3/2.5) from 4;

    loop(3, $i) fro%m 5 {
        num $offset = $#i * 3;

        play (A2/2, B2/2) from $offset;
        $$

        if ($i % 2 = 0) {
            play C3 from $offset + 1;
        } else {
            play D3 from $offset + 1;
        }
    }
}

play !intro_1 using saw from 0;
